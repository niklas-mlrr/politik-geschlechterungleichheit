---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Internationale Geschlechterungleichheit',
  description =
    'Interaktive Scrollytelling-Seite zur weltweiten Geschlechtergerechtigkeit. ' +
    'Datenbasis: WEF Global Gender Gap Report 2025.',
} = Astro.props;

// Inhaltsverzeichnis – Anker zu den Sektions-IDs (müssen zu den section-Komponenten passen)
const nav = [
  { id: 'definition', label: 'Begriff' },
  { id: 'karte', label: 'Welt' },
  { id: 'vorbilder', label: 'Vorbilder' },
  { id: 'schlusslichter', label: 'Schlusslichter' },
  { id: 'daten', label: 'Daten' },
  { id: 'zeitstrahl', label: 'Zeitstrahl' },
  { id: 'stimmen', label: 'Stimmen' },
  { id: 'quellen', label: 'Quellen' },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <a href="#hauptinhalt" class="skip-link">Zum Inhalt springen</a>

    <header class="site-header">
      <nav class="site-nav" aria-label="Inhaltsverzeichnis">
        <a href="#hero" class="brand">Gleichstellung</a>
        <ul class="nav-list">
          {
            nav.map((item) => (
              <li>
                <a href={`#${item.id}`}>{item.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main id="hauptinhalt">
      <slot />
    </main>

    <footer class="site-footer">
      <p>Schulprojekt Politik · Datenbasis: WEF Global Gender Gap Report 2025</p>
    </footer>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        background: var(--color-clay);
        color: #fff;
        padding: 0.6rem 1rem;
        border-radius: 0 0 0.4rem 0;
      }
      .skip-link:focus {
        left: 0;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(10px);
        background: color-mix(in srgb, var(--color-sand) 82%, transparent);
        border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 8%, transparent);
      }
      .site-nav {
        max-width: 72rem;
        margin: 0 auto;
        padding: 0.75rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
      .brand {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--color-clay);
        text-decoration: none;
        flex-shrink: 0;
      }
      .nav-list {
        display: flex;
        gap: 1.1rem;
        flex-wrap: wrap;
        list-style: none;
        margin: 0;
        padding: 0;
        font-size: 0.95rem;
      }
      .nav-list a {
        color: var(--color-subtext);
        text-decoration: none;
        transition: color 0.18s ease;
      }
      .nav-list a:hover {
        color: var(--color-ink);
      }

      .site-footer {
        max-width: 72rem;
        margin: 0 auto;
        padding: 3rem 1.25rem 4rem;
        color: var(--color-subtext);
        font-size: 0.9rem;
        border-top: 1px solid color-mix(in srgb, var(--color-ink) 8%, transparent);
      }
    </style>
  </body>
</html>
