---
// Vorbilder – Länder, die beim Schließen des Gender Gap vorangehen.
// 4 Ranking-Karten + Island als Schwerpunkt-Beispiel + kompakte „Weitere Top 10“-Liste.
import Section from '../ui/Section.astro';
import CountryCard from '../ui/CountryCard.astro';
import MediaGrid from '../ui/MediaGrid.astro';
import SourceTooltip from '../ui/SourceTooltip.astro';
import { vorbilder } from '../../data/content';
---

<Section
  id="vorbilder"
  surface="card"
  eyebrow="Vorbilder"
  title="Wer vorangeht"
  intro={vorbilder.intro}
>
  <MediaGrid columns={2}>
    {vorbilder.laender.map((l) => <CountryCard {...l} />)}
  </MediaGrid>

  <div class="island-focus">
    <h3 class="island-titel">Schwerpunkt Island</h3>
    <p class="island-lead">
      Island führt das Ranking seit 16 Jahren an. Vier Felder zeigen, woran das liegt.
    </p>
    <div class="island-grid">
      {
        vorbilder.islandFakten.map((f) => (
          <article class="island-card">
            <h4 class="island-card-titel">{f.titel}</h4>
            <p class="island-card-text">
              {f.text}
              {f.quellen.map((id) => (
                <SourceTooltip id={id} />
              ))}
            </p>
          </article>
        ))
      }
    </div>
  </div>

  <h3 class="weitere-titel">Weitere Länder der Top 10</h3>
  <ul class="weitere-liste">
    {
      vorbilder.weitere.map((l) => (
        <li class="weitere-item">
          <span class="weitere-platz">{l.platz}</span>
          <span class="weitere-body">
            <span class="weitere-land">{l.land}</span>
            <span class="weitere-prozent">
              {(l.closed * 100).toFixed(1).replace('.', ',')}&thinsp;%
            </span>
            <span class="weitere-kurz">
              {l.kurz}
              {l.quellen.map((id) => (
                <SourceTooltip id={id} />
              ))}
            </span>
          </span>
        </li>
      ))
    }
  </ul>
</Section>

<style>
  .island-focus {
    margin-top: 3rem;
    padding: 1.75rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-ocker) 16%, var(--color-sand));
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
  }
  .island-titel {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
  }
  .island-lead {
    margin: 0.4rem 0 1.5rem;
    color: var(--color-subtext);
  }
  .island-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 48rem) {
    .island-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .island-card {
    background: var(--color-card);
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 0.85rem;
    padding: 1.1rem 1.2rem;
  }
  .island-card-titel {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-clay);
    margin: 0 0 0.4rem;
  }
  .island-card-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-ink);
  }

  .weitere-titel {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    margin: 3rem 0 1.25rem;
  }
  .weitere-liste {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .weitere-item {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    background: var(--color-card);
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 0.7rem;
  }
  .weitere-platz {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-clay);
    text-align: center;
  }
  .weitere-body {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.3rem 0.6rem;
  }
  .weitere-land {
    font-weight: 700;
  }
  .weitere-prozent {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-sage);
  }
  .weitere-kurz {
    flex: 1 1 100%;
    font-size: 0.92rem;
    color: var(--color-subtext);
  }
</style>
