---
// Vorbilder – Länder, die beim Schließen des Gender Gap vorangehen.
// Zeigt Ranking-Karten und einen Beispiel-Steckbrief / Portrait-Platzhalter (Sketch S.1),
// um zu zeigen, wie spätere Personen-Porträts aussehen.
import Section from '../ui/Section.astro';
import CountryCard from '../ui/CountryCard.astro';
import MediaGrid from '../ui/MediaGrid.astro';
import { vorbilder } from '../../data/placeholder';
---

<Section
  id="vorbilder"
  surface="card"
  eyebrow="Vorbilder"
  title="Wer vorangeht"
  intro={vorbilder.intro}
>
  <MediaGrid columns={2}>
    {vorbilder.laender.map((l) => <CountryCard {...l} />)}
  </MediaGrid>

</Section>

<style>
</style>
