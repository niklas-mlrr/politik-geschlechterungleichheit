---
// Zeitstrahl – zeitliche Entwicklung der Gleichstellung (Sketch S.4).
// Statischer, gestalteter horizontaler Zeitstrahl mit Knoten je Ereignis.
// Auf Mobil bricht der Strahl vertikal um.
// Progressive Enhancement (wie WorldMap): Ohne JS sind alle Karten voll lesbar.
// Mit JS (data-ready) werden die Karten kompakt (Jahr + Titel) und ein geteiltes
// Detail-Panel zeigt bei Klick Ort/Jahr/Text/optional Zitat+Bild des Ereignisses.
import Section from '../ui/Section.astro';
import SourceTooltip from '../ui/SourceTooltip.astro';
import { zeitstrahl, type TimelineEvent } from '../../data/content';
---

<Section
  id="zeitstrahl"
  eyebrow="Zeitliche Entwicklung"
  title="Wichtige Schritte"
  intro={zeitstrahl.intro}
>
  <ol class="timeline" role="list" data-island="timeline">
    {
      zeitstrahl.ereignisse.map((e: TimelineEvent, i) => (
        <li class:list={['tl-item', i % 2 === 0 ? 'is-above' : 'is-below']}>
          <span class="tl-node" aria-hidden="true" />
          <button
            type="button"
            class="tl-card tl-trigger"
            aria-expanded="false"
            aria-controls="tl-detail"
            data-jahr={e.jahr}
            data-ort={e.ort}
            data-titel={e.titel}
            data-text={e.text}
            data-zitat={e.zitat ?? ''}
            data-bild={e.bild ?? ''}
            data-bildalt={e.bildAlt ?? ''}
            data-bildcredit={e.bildCredit ?? ''}
            data-quellen={e.quellen.join(',')}
          >
            <span class="tl-jahr">{e.jahr}</span>
            <span class="tl-titel">{e.titel}</span>
            <span class="tl-ort">
              <svg
                class="tl-pin"
                viewBox="0 0 24 24"
                width="13"
                height="13"
                aria-hidden="true"
              >
                <path
                  d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7z"
                  fill="currentColor"
                />
                <circle cx="12" cy="9" r="2.5" fill="var(--color-card)" />
              </svg>
              <span>{e.ort}</span>
            </span>
            {/* Volltext: ohne JS sichtbar (Fallback), im kompakten JS-Modus ausgeblendet. */}
            <span class="tl-text">{e.text}</span>
          </button>
          {/* Quellen ausserhalb des Buttons (kein <a> in <button>); ohne JS sichtbar,
              im kompakten JS-Modus wandert die Quellenangabe ins Detail-Panel. */}
          <p class="tl-quellen">
            {e.quellen.map((id) => (
              <SourceTooltip id={id} />
            ))}
          </p>
        </li>
      ))
    }
  </ol>

  {/* Geteiltes Detail-Panel – wird per JS befüllt. Ohne JS ungenutzt (hidden). */}
  <div
    class="tl-detail"
    id="tl-detail"
    role="region"
    aria-label="Ereignis-Details"
    aria-live="polite"
    hidden
  >
    <button type="button" class="tl-detail-close" aria-label="Details schließen">×</button>
    <p class="tl-detail-meta">
      <span class="tl-detail-jahr"></span>
      <span class="tl-detail-ort"></span>
    </p>
    <h3 class="tl-detail-titel"></h3>
    <p class="tl-detail-text"></p>
    <p class="tl-detail-quellen"></p>
    <blockquote class="tl-detail-zitat" hidden></blockquote>
    <figure class="tl-detail-bild" hidden>
      <img alt="" />
      <figcaption class="tl-detail-credit"></figcaption>
    </figure>
  </div>
</Section>

<style>
  /* Horizontaler Zeitstrahl ab Tablet-Breite. */
  .timeline {
    /* Positionierungskontext für .timeline::before – sonst landet die Linie
       relativ zum Viewport (bei 50vh quer durch den Hero). */
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }

  .tl-item {
    position: relative;
    padding-left: 2rem;
  }

  /* Vertikale Linie (mobil) */
  .timeline::before {
    content: '';
    position: absolute;
    left: 0.5rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: color-mix(in srgb, var(--color-ocker) 60%, transparent);
  }

  .tl-node {
    position: absolute;
    left: calc(0.5rem - 5px);
    top: 0.55rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-clay);
    border: 2px solid var(--color-sand);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-clay) 35%, transparent);
    z-index: 1;
  }

  /* Karte = Button (Trigger). Reset auf neutrales Erscheinungsbild. */
  .tl-card {
    display: block;
    width: 100%;
    text-align: left;
    font: inherit;
    color: inherit;
    appearance: none;
    cursor: default;
    background: var(--color-card);
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 0.9rem;
    padding: 1rem 1.1rem;
    box-shadow: 0 1px 3px color-mix(in srgb, var(--color-ink) 8%, transparent);
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease;
  }

  .tl-jahr {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-clay);
  }
  .tl-titel {
    display: block;
    font-size: 1.05rem;
    font-weight: 700;
    margin-top: 0.2rem;
    /* Schmale, überlappende Karten -> lange Wörter umbrechen, nicht überlaufen. */
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .tl-ort {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-sage);
  }
  .tl-pin {
    color: var(--color-clay);
  }
  .tl-text {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-subtext);
  }

  /* ---------- Interaktiver Modus (JS aktiv) ---------- */
  .timeline[data-ready] .tl-card {
    cursor: pointer;
  }
  /* Kompakt: Volltext + Fallback-Quellen wandern ins geteilte Detail-Panel. */
  .timeline[data-ready] .tl-text,
  .timeline[data-ready] .tl-quellen {
    display: none;
  }

  /* Fallback-Quellen (ohne JS) unter der Karte. */
  .tl-quellen {
    margin: 0.4rem 0 0;
    padding-left: 2rem;
    font-size: 0.85rem;
  }

  .tl-detail-quellen {
    margin: 0.6rem 0 0;
    font-size: 0.85rem;
    color: var(--color-subtext);
  }
  .tl-detail-quellen :global(.tl-quelle-ref) {
    color: var(--color-clay);
    font-weight: 600;
    text-decoration: none;
  }
  .tl-detail-quellen :global(.tl-quelle-ref:hover) {
    text-decoration: underline;
  }
  .timeline[data-ready] .tl-card:hover,
  .timeline[data-ready] .tl-card:focus-visible {
    border-color: color-mix(in srgb, var(--color-clay) 50%, transparent);
    box-shadow: 0 4px 14px color-mix(in srgb, var(--color-ink) 14%, transparent);
    transform: translateY(-2px);
  }
  .timeline[data-ready] .tl-card[aria-expanded='true'] {
    border-color: var(--color-clay);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-clay) 30%, transparent);
  }

  /* ---------- Geteiltes Detail-Panel ---------- */
  .tl-detail {
    position: relative;
    margin-top: 2.5rem;
    padding: 1.4rem 1.6rem 1.6rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-card) 70%, var(--color-sand));
    border: 1px solid color-mix(in srgb, var(--color-ink) 12%, transparent);
    box-shadow: 0 6px 22px color-mix(in srgb, var(--color-ink) 12%, transparent);
  }
  .tl-detail[hidden] {
    display: none;
  }
  .tl-detail-close {
    position: absolute;
    top: 0.5rem;
    right: 0.7rem;
    width: 1.8rem;
    height: 1.8rem;
    border: 0;
    background: none;
    color: var(--color-subtext);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    border-radius: 0.4rem;
  }
  .tl-detail-close:hover {
    color: var(--color-ink);
  }
  .tl-detail-meta {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-subtext);
  }
  .tl-detail-jahr {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-clay);
  }
  .tl-detail-ort {
    font-weight: 600;
    color: var(--color-sage);
  }
  .tl-detail-titel {
    margin: 0.3rem 0 0;
    font-size: 1.3rem;
    font-weight: 700;
  }
  .tl-detail-text {
    margin: 0.7rem 0 0;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-ink);
    max-width: 46rem;
  }
  .tl-detail-zitat {
    margin: 1rem 0 0;
    padding-left: 1rem;
    border-left: 3px solid color-mix(in srgb, var(--color-clay) 60%, transparent);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-ink);
    max-width: 46rem;
  }
  .tl-detail-zitat[hidden] {
    display: none;
  }
  .tl-detail-bild {
    margin: 1.1rem 0 0;
  }
  .tl-detail-bild[hidden] {
    display: none;
  }
  .tl-detail-bild img {
    display: block;
    max-width: min(100%, 30rem);
    border-radius: 0.7rem;
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
  }
  .tl-detail-credit {
    margin: 0.4rem 0 0;
    font-size: 0.72rem;
    font-style: italic;
    color: var(--color-subtext);
  }
  .tl-detail-credit:empty {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-card {
      transition: none;
    }
    .timeline[data-ready] .tl-card:hover,
    .timeline[data-ready] .tl-card:focus-visible {
      transform: none;
    }
  }

  /* Ab Tablet: horizontaler Strahl mit abwechselnd oben/unten platzierten Karten.
     Die Karten docken nah an der Mittellinie an und überlappen sie leicht (statt
     ganz nach oben/unten gedrückt zu werden) -> deutlich kompakteres vertikales
     Spacing. Sie sind breiter als ihre Spalte und ragen in die Nachbarspalten;
     da benachbarte Karten auf der jeweils anderen Seite liegen, kollidieren sie
     nicht. `minmax(0,1fr)` + `min-width:0` verhindern, dass lange Wörter die
     Spalten (und damit die Seite) horizontal überlaufen lassen. */
  @media (min-width: 48rem) {
    /* Nur im JS-Modus horizontal: Die kompakten Karten (Jahr + Titel) werden
       absolut zur Mittellinie positioniert. Ohne JS bleibt die vertikale
       Variante von oben aktiv (Volltext-Karten, kein Overflow, voll lesbar). */
    .timeline[data-ready] {
      grid-auto-flow: column;
      grid-auto-columns: minmax(0, 1fr);
      gap: 0;
      /* Innenabstand, damit die Rand-Karten Platz haben, ohne die Seite zu
         verbreitern. */
      padding-inline: 1.5rem;
      padding-block: 1rem;
      align-items: center;
      /* Reserviert vertikalen Platz für die out-of-flow Karten (oben + unten). */
      min-height: 22rem;
    }
    .timeline[data-ready]::before {
      left: 0;
      right: 0;
      top: 50%;
      bottom: auto;
      width: auto;
      height: 2px;
    }
    .timeline[data-ready] .tl-item {
      position: relative;
      padding-left: 0;
      padding-inline: 0;
      min-width: 0;
      min-height: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .timeline[data-ready] .tl-node {
      position: static;
      left: auto;
      top: auto;
    }
    /* Karte absolut zur Mittellinie positioniert, an der Linie angedockt. */
    .timeline[data-ready] .tl-card {
      position: absolute;
      /* Zentrierung über margin (nicht transform) -> transform bleibt frei für
         den Hover-Lift; -75% = halbe Kartenbreite (50% von 150%). */
      left: 50%;
      margin-left: -75%;
      /* Breiter als die Spalte -> ragt in beide Nachbarn (Gegenseite, kein
         Konflikt); schmaler als zuvor -> mehr Luft zwischen den Karten. */
      width: 150%;
      max-width: 12rem;
    }
    .timeline[data-ready] .is-above .tl-card {
      bottom: calc(50% + 0.85rem);
    }
    .timeline[data-ready] .is-below .tl-card {
      top: calc(50% + 0.85rem);
    }
    /* Rand-Karten nach innen ausrichten, damit sie nicht über den Strahl
       hinausragen und erneut horizontalen Scroll auslösen. */
    .timeline[data-ready] .tl-item:first-child .tl-card {
      left: 0;
      margin-left: 0;
    }
    .timeline[data-ready] .tl-item:last-child .tl-card {
      left: auto;
      right: 0;
      margin-left: 0;
    }
  }
</style>

<script>
  // JS-Insel: Karten-Klick -> geteiltes Detail-Panel befüllen & einblenden.
  // Progressive Enhancement: ohne JS bleiben die Volltexte in den Karten sichtbar.
  function initTimeline(list: HTMLElement) {
    const detail = document.getElementById('tl-detail');
    if (!detail) return;

    const el = {
      jahr: detail.querySelector<HTMLElement>('.tl-detail-jahr')!,
      ort: detail.querySelector<HTMLElement>('.tl-detail-ort')!,
      titel: detail.querySelector<HTMLElement>('.tl-detail-titel')!,
      text: detail.querySelector<HTMLElement>('.tl-detail-text')!,
      quellen: detail.querySelector<HTMLElement>('.tl-detail-quellen')!,
      zitat: detail.querySelector<HTMLElement>('.tl-detail-zitat')!,
      bildFig: detail.querySelector<HTMLElement>('.tl-detail-bild')!,
      bildImg: detail.querySelector<HTMLImageElement>('.tl-detail-bild img')!,
      bildCredit: detail.querySelector<HTMLElement>('.tl-detail-credit')!,
    };
    const closeBtn = detail.querySelector<HTMLElement>('.tl-detail-close');
    const triggers = Array.from(list.querySelectorAll<HTMLElement>('.tl-trigger'));
    let active: HTMLElement | null = null;

    // Erst jetzt auf kompakt schalten (CSS sieht data-ready) – ohne JS bleibt Volltext.
    list.setAttribute('data-ready', '');

    function close() {
      detail!.hidden = true;
      active?.setAttribute('aria-expanded', 'false');
      active = null;
    }

    function open(trigger: HTMLElement) {
      const d = trigger.dataset;
      el.jahr.textContent = d.jahr || '';
      el.ort.textContent = d.ort || '';
      el.titel.textContent = d.titel || '';
      el.text.textContent = d.text || '';

      // Quelle(n) als Anker-Links auf die Quellen-Sektion (#quelle-n).
      const ids = (d.quellen || '').split(',').map((s) => s.trim()).filter(Boolean);
      el.quellen.textContent = ids.length ? 'Quelle: ' : '';
      ids.forEach((id, i) => {
        const a = document.createElement('a');
        a.href = '#quelle-' + id;
        a.className = 'tl-quelle-ref';
        a.textContent = '[' + id + ']';
        el.quellen.appendChild(a);
        if (i < ids.length - 1) el.quellen.appendChild(document.createTextNode(' '));
      });

      const zitat = (d.zitat || '').trim();
      el.zitat.hidden = zitat === '';
      el.zitat.textContent = zitat;

      const bild = (d.bild || '').trim();
      el.bildFig.hidden = bild === '';
      if (bild) {
        el.bildImg.src = bild;
        el.bildImg.alt = d.bildalt || d.titel || '';
        const credit = (d.bildcredit || '').trim();
        el.bildCredit.textContent = credit ? 'Foto: ' + credit : '';
      }

      active?.setAttribute('aria-expanded', 'false');
      active = trigger;
      trigger.setAttribute('aria-expanded', 'true');
      detail!.hidden = false;
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        if (active === trigger) close();
        else open(trigger);
      });
    });

    closeBtn?.addEventListener('click', () => {
      const last = active;
      close();
      last?.focus();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !detail!.hidden) {
        const last = active;
        close();
        last?.focus();
      }
    });
    // Klick außerhalb des Panels (und nicht auf eine Karte) schließt es.
    document.addEventListener('click', (e) => {
      if (detail!.hidden) return;
      const target = e.target as Node;
      if (detail!.contains(target)) return; // Klick im Panel selbst
      if (triggers.some((t) => t.contains(target))) return; // Karten togglen selbst
      close();
    });
  }

  document
    .querySelectorAll<HTMLElement>('[data-island="timeline"]')
    .forEach((list) => initTimeline(list));
</script>
