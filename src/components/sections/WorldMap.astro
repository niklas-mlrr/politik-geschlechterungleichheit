---
// WorldMap – Herzstück: globaler Überblick als interaktive Weltkarte (Sketch S.0).
// Statisches Gerüst: die echte Leaflet-Choropleth folgt später und dockt an den
// DataPlaceholder (data-island="map") an. Hier nur Platzhalter + statische Legende
// + ein ruhiges Info-Box-Mockup, das einen späteren Land-Klick andeutet.
import Section from '../ui/Section.astro';
import DataPlaceholder from '../ui/DataPlaceholder.astro';
import { karte } from '../../data/placeholder';
---

<Section
  id="karte"
  wide
  eyebrow="Globaler Überblick"
  title="Die Welt im Vergleich"
  intro={karte.intro}
>
  <div class="map-stage">
    <DataPlaceholder
      island="map"
      label="Interaktive Weltkarte"
      ratio="2/1"
      hint={karte.islandHinweis}
    >
      {/* Andeutung eines Land-Klicks: Pin -> Infobox (statisch, ruhig). */}
      <figure class="info-box" aria-label="Beispiel einer Land-Infobox (Platzhalter)">
        <span class="info-pin" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
            stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
            stroke-linejoin="round">
            <path d="M12 21s7-5.4 7-11a7 7 0 1 0-14 0c0 5.6 7 11 7 11Z" />
            <circle cx="12" cy="10" r="2.5" />
          </svg>
        </span>
        <figcaption class="info-body">
          <span class="info-land">Land</span>
          <span class="info-meta">
            <span class="info-platz">Platz&nbsp;–</span>
            <span class="info-prozent">–&nbsp;%</span>
          </span>
          <span class="info-hint">Beispiel-Infobox</span>
        </figcaption>
      </figure>
    </DataPlaceholder>

    {/* Statische Choropleth-Legende: Rot = wenig, Grün = viel Gleichstellung. */}
    <div class="legend" aria-hidden="true">
      <div class="legend-bar"></div>
      <ul class="legend-labels">
        <li class="legend-low">{karte.legende.low}</li>
        <li class="legend-mid">{karte.legende.mid}</li>
        <li class="legend-high">{karte.legende.high}</li>
      </ul>
    </div>
  </div>
</Section>

<style>
  .map-stage {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ---------- Info-Box-Mockup (Pin -> Infobox) ---------- */
  .info-box {
    position: absolute;
    top: 12%;
    left: 8%;
    max-width: min(16rem, 60%);
    margin: 0;
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.75rem 0.9rem;
    border-radius: 0.85rem;
    background: color-mix(in srgb, var(--color-card) 88%, var(--color-sand));
    border: 1px solid color-mix(in srgb, var(--color-ink) 12%, transparent);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--color-ink) 12%, transparent);
  }
  .info-pin {
    flex: none;
    display: inline-flex;
    color: var(--color-clay);
    margin-top: 0.1rem;
  }
  .info-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .info-land {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-ink);
  }
  .info-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-subtext);
  }
  .info-prozent {
    color: var(--color-sage);
    font-weight: 600;
  }
  .info-hint {
    margin-top: 0.15rem;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-subtext);
  }

  @media (max-width: 36rem) {
    .info-box {
      display: none; /* auf sehr schmalen Screens dezent ausblenden */
    }
  }

  /* ---------- Choropleth-Legende ---------- */
  .legend {
    max-width: 46rem;
  }
  .legend-bar {
    height: 0.85rem;
    border-radius: 999px;
    background: linear-gradient(
      to right,
      var(--color-gap-low),
      var(--color-gap-mid),
      var(--color-gap-high)
    );
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
  }
  .legend-labels {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    margin: 0.6rem 0 0;
    padding: 0;
    list-style: none;
    font-size: 0.85rem;
    color: var(--color-subtext);
  }
  .legend-low {
    text-align: left;
    color: var(--color-gap-low);
    font-weight: 600;
  }
  .legend-mid {
    text-align: center;
  }
  .legend-high {
    text-align: right;
    color: var(--color-gap-high);
    font-weight: 600;
  }
</style>
