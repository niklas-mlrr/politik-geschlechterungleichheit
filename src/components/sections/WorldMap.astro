---
// WorldMap – Herzstück: globaler Überblick als grobe, stilisierte Weltkarte.
// Keine echte Choropleth, sondern eine ruhige Land-Silhouette (1 Pfad) mit
// markierten Punkten (Pins) für ausgewählte Vorbild-/Schlusslicht-Länder.
// Pin antippen -> eine geteilte Infokarte fährt am Punkt aus (kleine JS-Insel).
// Ohne JS / auf schmalen Screens bleibt die Länderliste unten lesbar.
import Section from '../ui/Section.astro';
import CountryCard from '../ui/CountryCard.astro';
import { karte } from '../../data/placeholder';
import { gapColor } from '../../data/tokens';
import { viewBox, landPath, coords } from '../../data/worldMap';

// viewBox -> Dimensionen für Pin-Position (%) und Bühnen-Seitenverhältnis.
const [, , VBW, VBH] = viewBox.split(' ').map(Number);

// Nur Pins rendern, für die eine Position vorliegt (Sicherheit).
const punkte = karte.punkte.filter((p) => coords[p.iso3]);
---

<Section
  id="karte"
  eyebrow="Globaler Überblick"
  title="Die Welt im Vergleich"
  intro={karte.intro}
>
  <div class="map-wrap" data-island="map">
    <div class="map-stage" style={`--map-ar:${VBW} / ${VBH};`}>
      {/* Land-Rahmen: hält das Karten-Seitenverhältnis und zentriert die Karte.
          So bleiben Pins (in %) deckungsgleich, auch wenn die Stage am Desktop
          höher ist (mehr Ozean oben/unten, Land bleibt zentriert). */}
      <div class="map-frame">
        <svg
          class="map-svg"
          viewBox={viewBox}
          preserveAspectRatio="xMidYMid meet"
          aria-hidden="true"
          focusable="false"
        >
          <path d={landPath} />
        </svg>

        <div class="pins">
        {
          punkte.map((p) => {
            const c = coords[p.iso3]!;
            const left = ((c.x / VBW) * 100).toFixed(2);
            const top = ((c.y / VBH) * 100).toFixed(2);
            return (
              <button
                type="button"
                class="pin"
                data-kat={p.kategorie}
                data-land={p.land}
                data-platz={p.platz}
                data-closed={p.closed}
                data-kurz={p.kurz}
                aria-haspopup="dialog"
                aria-expanded="false"
                aria-label={`${p.land}, Platz ${p.platz} – Infokarte öffnen`}
                style={`left:${left}%; top:${top}%; color:${gapColor(p.closed)};`}
              >
                <span class="pin-dot" aria-hidden="true" />
              </button>
            );
          })
        }
        </div>
      </div>

      {/* Geteilte Infokarte – wird per JS befüllt & positioniert. */}
      <div class="ci-card" role="dialog" aria-label="Länder-Info" hidden>
        <button type="button" class="ci-close" aria-label="Infokarte schließen">×</button>
        <p class="ci-land"></p>
        <p class="ci-meta">
          <span class="ci-platz"></span>
          <span class="ci-prozent"></span>
        </p>
        <div class="ci-bar"><span class="ci-bar-fill"></span></div>
        <p class="ci-kurz"></p>
      </div>
    </div>

    {/* Legende: Farbskala (rot = wenig, grün = viel geschlossen) */}
    <div class="legend">
      <div class="legend-scale" aria-hidden="true">
        <span class="legend-cap">{karte.legende.low}</span>
        <span class="legend-bar"></span>
        <span class="legend-cap">{karte.legende.high}</span>
      </div>
      <p class="legend-title">{karte.legende.titel}</p>
      <p class="legend-hint">{karte.hinweis}</p>
    </div>

    {/* Fallback / a11y: lesbar ohne JS und auf schmalen Screens. */}
    <ul class="country-list">
      {
        punkte.map((p) => (
          <li>
            <CountryCard land={p.land} platz={p.platz} closed={p.closed} kurz={p.kurz} />
          </li>
        ))
      }
    </ul>
    <noscript>
      <style>.country-list { display: grid !important; }</style>
    </noscript>
  </div>
</Section>

<style>
  .map-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ---------- Karten-Bühne ---------- */
  .map-stage {
    position: relative;
    width: 100%;
    /* Default (Mobil/iPad): Stage == Land-Rahmen -> exakt wie zuvor. */
    aspect-ratio: var(--map-ar);
    display: flex;
    align-items: center; /* Land vertikal zentrieren, falls Stage höher ist */
    border-radius: 1rem;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 30% 25%,
        color-mix(in srgb, var(--color-ocean) 60%, var(--color-card)),
        var(--color-ocean)
      );
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
  }
  /* Land-Rahmen: trägt das Karten-Seitenverhältnis; Pins liegen auf diesem Rahmen. */
  .map-frame {
    position: relative;
    width: 100%;
    aspect-ratio: var(--map-ar);
  }

  /* PC/Laptop (Maus, breiter Viewport): Stage höher, Land bleibt zentriert.
     iPad/Touch ausgeschlossen via hover/pointer -> dort alles unverändert. */
  @media (hover: hover) and (pointer: fine) and (min-width: 64rem) {
    .map-stage {
      aspect-ratio: 1000 / 500; /* flacher Default ~2,58:1 -> ~2:1, mehr Höhe */
    }
  }
  .map-svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .map-svg path {
    /* warme Landfläche, deutlich abgesetzt vom Ozean, keine Grenzlinien */
    fill: color-mix(in srgb, var(--color-ocker) 30%, var(--color-card));
    stroke: color-mix(in srgb, var(--color-ink) 7%, transparent);
    stroke-width: 0.4;
  }

  /* ---------- Pins ---------- */
  .pins {
    position: absolute;
    inset: 0;
  }
  .pin {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--color-clay);
  }
  .pin-dot {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 999px;
    background: currentColor;
    border: 2px solid var(--color-sand);
    box-shadow: 0 1px 4px color-mix(in srgb, var(--color-ink) 35%, transparent);
    transition: transform 0.15s ease;
  }
  /* Pin-Farbe kommt per Inline-Style aus gapColor(closed) -> currentColor. */
  .pin:hover .pin-dot,
  .pin:focus-visible .pin-dot,
  .pin[aria-expanded='true'] .pin-dot {
    transform: scale(1.3);
  }
  .pin[aria-expanded='true'] .pin-dot {
    box-shadow: 0 0 0 4px color-mix(in srgb, currentColor 30%, transparent);
  }

  /* ---------- Infokarte (per JS positioniert) ---------- */
  .ci-card {
    position: absolute;
    z-index: 5;
    width: min(17rem, 78%);
    margin: 0;
    padding: 0.85rem 0.95rem 1rem;
    border-radius: 0.85rem;
    background: color-mix(in srgb, var(--color-card) 92%, var(--color-sand));
    border: 1px solid color-mix(in srgb, var(--color-ink) 14%, transparent);
    box-shadow: 0 8px 28px color-mix(in srgb, var(--color-ink) 22%, transparent);
  }
  .ci-card[hidden] { display: none; }
  .ci-close {
    position: absolute;
    top: 0.3rem;
    right: 0.45rem;
    width: 1.6rem;
    height: 1.6rem;
    border: 0;
    background: none;
    color: var(--color-subtext);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    border-radius: 0.4rem;
  }
  .ci-close:hover { color: var(--color-ink); }
  .ci-land {
    margin: 0;
    padding-right: 1.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-ink);
  }
  .ci-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
    margin: 0.15rem 0 0.55rem;
    font-size: 0.85rem;
    color: var(--color-subtext);
  }
  .ci-prozent {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-clay);
  }
  .ci-bar {
    height: 0.45rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-ink) 8%, var(--color-sand));
    overflow: hidden;
  }
  .ci-bar-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    transition: width 0.3s ease;
  }
  .ci-kurz {
    margin: 0.7rem 0 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-ink);
  }

  /* ---------- Legende (Farbskala) ---------- */
  .legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1.25rem;
    font-size: 0.9rem;
    color: var(--color-subtext);
  }
  .legend-scale {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex: 1 1 18rem;
  }
  .legend-cap {
    white-space: nowrap;
    font-size: 0.82rem;
  }
  .legend-bar {
    position: relative;
    flex: 1 1 auto;
    min-width: 6rem;
    height: 0.6rem;
    border-radius: 0.35rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    /* Container erzwingt nur die Rundung + Clipping. */
  }
  /* Verlauf auf eigenes ::before, damit WebKit/iPad die border-radius-Rundung
     zuverlässig umsetzt (Bug: lineare Verläufe direkt auf .legend-bar werden
     bei nicht-100%-Hintergrundgröße nicht vom radius des Containers geclippt,
     und background-size:100% 100% bricht die Rundung in einem anderen WebKit-Pfad).
     Eigener Layer mit 100% Größe + radius:inherit -> konsistent in allen Browsern. */
  .legend-bar::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      to right,
      var(--color-gap-low) 0%,
      var(--color-gap-mid) 50%,
      var(--color-gap-high) 100%
    );
    background-repeat: no-repeat;
    pointer-events: none;
  }
  .legend-title {
    margin: 0;
    font-size: 0.82rem;
  }
  .legend-hint {
    margin: 0 0 0 auto;
    font-style: italic;
  }

  /* ---------- Fallback-Liste ---------- */
  .country-list {
    display: none; /* Desktop+JS: nur Karte. Mobil/Noscript: eingeblendet. */
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 1rem;
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
  }
  @media (max-width: 48rem) {
    .country-list { display: grid; }
    .legend-hint { display: none; }
  }
</style>

<script>
  // Kleine JS-Insel: Pin-Klick -> geteilte Infokarte befüllen & am Pin positionieren.
  import { gapColor } from '../../data/tokens';

  function initMap(wrap: HTMLElement) {
    const stage = wrap.querySelector<HTMLElement>('.map-stage');
    const card = wrap.querySelector<HTMLElement>('.ci-card');
    if (!stage || !card) return;

    const el = {
      land: card.querySelector<HTMLElement>('.ci-land')!,
      platz: card.querySelector<HTMLElement>('.ci-platz')!,
      prozent: card.querySelector<HTMLElement>('.ci-prozent')!,
      fill: card.querySelector<HTMLElement>('.ci-bar-fill')!,
      kurz: card.querySelector<HTMLElement>('.ci-kurz')!,
    };
    const closeBtn = card.querySelector<HTMLElement>('.ci-close');
    let active: HTMLElement | null = null;

    function close() {
      card!.hidden = true;
      active?.setAttribute('aria-expanded', 'false');
      active = null;
    }

    function place(pin: HTMLElement) {
      const sr = stage!.getBoundingClientRect();
      const pr = pin.getBoundingClientRect();
      const cw = card!.offsetWidth;
      const ch = card!.offsetHeight;
      const pinX = pr.left - sr.left + pr.width / 2;
      const pinTop = pr.top - sr.top;
      let x = pinX - cw / 2;
      let y = pinTop - ch - 10; // bevorzugt oberhalb des Pins
      if (y < 6) y = pinTop + pr.height + 10; // sonst darunter
      x = Math.max(6, Math.min(x, sr.width - cw - 6));
      y = Math.max(6, Math.min(y, sr.height - ch - 6));
      card!.style.left = x + 'px';
      card!.style.top = y + 'px';
    }

    function open(pin: HTMLElement) {
      const d = pin.dataset;
      const closed = parseFloat(d.closed || '0');
      el.land.textContent = d.land || '';
      el.platz.textContent = 'Platz ' + d.platz + ' / 148';
      el.prozent.textContent = (closed * 100).toFixed(1).replace('.', ',') + ' %';
      el.fill.style.width = (closed * 100).toFixed(1) + '%';
      el.fill.style.background = gapColor(closed);
      el.kurz.textContent = d.kurz || '';

      active?.setAttribute('aria-expanded', 'false');
      active = pin;
      card!.hidden = false; // sichtbar -> messbar
      place(pin);
      pin.setAttribute('aria-expanded', 'true');
    }

    wrap.querySelectorAll<HTMLElement>('.pin').forEach((pin) => {
      pin.addEventListener('click', (e) => {
        e.stopPropagation();
        if (active === pin) close();
        else open(pin);
      });
    });

    closeBtn?.addEventListener('click', close);
    document.addEventListener('click', (e) => {
      if (!card!.hidden && !card!.contains(e.target as Node)) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !card!.hidden) {
        const last = active;
        close();
        last?.focus();
      }
    });
    window.addEventListener('resize', close);
  }

  document
    .querySelectorAll<HTMLElement>('[data-island="map"]')
    .forEach((wrap) => initMap(wrap));
</script>
