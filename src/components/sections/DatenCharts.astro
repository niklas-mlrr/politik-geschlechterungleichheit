---
// DatenCharts – Daten-Sektion: drei Diagramme schärfen das Bild der Karte.
// Statisches Gerüst: die echten Chart.js-Diagramme folgen später und docken an
// die DataPlaceholder (data-island="chart") an. Dezente Kernzahl als Anker.
import Section from '../ui/Section.astro';
import DataPlaceholder from '../ui/DataPlaceholder.astro';
import MediaGrid from '../ui/MediaGrid.astro';
import { charts, kernzahlen } from '../../data/placeholder';

const weltdurchschnitt = Math.round(kernzahlen.weltdurchschnittClosed * 1000) / 10;
const weltProzent = weltdurchschnitt.toLocaleString('de-DE', {
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
---

<Section
  id="daten"
  surface="card"
  eyebrow="Daten"
  title="Zahlen, die das Bild schärfen"
  intro={charts.intro}
>
  <p class="kennzahl" aria-label={`Weltdurchschnitt: ${weltProzent} Prozent des Gender Gap geschlossen`}>
    <span class="kennzahl-wert">{weltProzent}&nbsp;%</span>
    <span class="kennzahl-text">des Gender Gap sind weltweit im Schnitt geschlossen.</span>
  </p>

  <MediaGrid columns={3}>
    <figure class="chart-card">
      <DataPlaceholder
        island="chart"
        label={charts.balkenTitel}
        ratio="4/3"
        hint="Balkendiagramm folgt im nächsten Ausbauschritt."
      />
      <figcaption class="chart-cap">{charts.balkenTitel}</figcaption>
    </figure>

    <figure class="chart-card">
      <DataPlaceholder
        island="chart"
        label={charts.linieTitel}
        ratio="4/3"
        hint="Liniendiagramm folgt im nächsten Ausbauschritt."
      />
      <figcaption class="chart-cap">{charts.linieTitel}</figcaption>
    </figure>

    <figure class="chart-card">
      <DataPlaceholder
        island="chart"
        label={charts.projektionTitel}
        ratio="4/3"
        hint="Projektion folgt im nächsten Ausbauschritt."
      />
      <figcaption class="chart-cap">{charts.projektionTitel}</figcaption>
    </figure>
  </MediaGrid>
</Section>

<style>
  .kennzahl {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.8rem;
    margin: 0 0 2.5rem;
    max-width: 40rem;
  }
  .kennzahl-wert {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 6vw, 3.4rem);
    line-height: 1;
    color: var(--color-clay);
  }
  .kennzahl-text {
    font-size: 1.1rem;
    color: var(--color-subtext);
    text-wrap: balance;
  }

  .chart-card {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .chart-cap {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--color-ink);
    text-wrap: balance;
  }
</style>
