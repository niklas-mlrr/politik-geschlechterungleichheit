---
// Ursachen – gemeinsame Muster der Spitzenländer.
// Wechsel-Grid aus Info-Box (titel + text + Quellen) und Bild-Platzhalter nach Sketch S.3.
import Section from '../ui/Section.astro';
import MediaGrid from '../ui/MediaGrid.astro';
import PlaceholderFigure from '../ui/PlaceholderFigure.astro';
import SourceTooltip from '../ui/SourceTooltip.astro';
import { ursachen } from '../../data/content';
---

<Section
  id="ursachen"
  eyebrow="Muster"
  title="Was die Spitzenländer gemeinsam haben"
  intro={ursachen.intro}
>
  <MediaGrid columns={2}>
    {
      ursachen.muster.map((m, i) => {
        const info = (
          <div class="ursachen-info">
            <h3 class="ursachen-titel">{m.titel}</h3>
            <p class="ursachen-text">
              {m.text}
              {m.quellen.map((id) => (
                <SourceTooltip id={id} />
              ))}
            </p>
          </div>
        );
        const bild = m.bild ? (
          <figure class="ursachen-figure">
            <img src={m.bild} alt={m.bildAlt ?? m.titel} loading="lazy" />
            {m.bildCredit && <figcaption class="ursachen-credit">Foto: {m.bildCredit}</figcaption>}
          </figure>
        ) : (
          <PlaceholderFigure ratio="4/3" label={m.titel} />
        );
        // Abwechselnd Info/Bild bzw. Bild/Info -> ruhiger Zickzack-Rhythmus.
        return i % 2 === 0 ? (
          <>
            {info}
            {bild}
          </>
        ) : (
          <>
            {bild}
            {info}
          </>
        );
      })
    }
  </MediaGrid>
</Section>

<style>
  .ursachen-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--color-card);
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 1rem;
    padding: 1.5rem;
  }
  .ursachen-titel {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
  }
  .ursachen-text {
    margin: 0;
    line-height: 1.65;
    color: var(--color-subtext);
  }
  .ursachen-figure {
    margin: 0;
    position: relative;
  }
  .ursachen-figure img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
  }
  .ursachen-credit {
    position: absolute;
    right: 0.5rem;
    bottom: 0.5rem;
    margin: 0;
    padding: 0.15rem 0.5rem;
    font-size: 0.7rem;
    line-height: 1.3;
    color: var(--color-sand);
    background: color-mix(in srgb, var(--color-ink) 62%, transparent);
    border-radius: 0.5rem;
    backdrop-filter: blur(2px);
  }
</style>
