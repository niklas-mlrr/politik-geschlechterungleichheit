---
// Ursachen – gemeinsame Muster der Spitzenländer.
import Section from '../ui/Section.astro';
import MediaGrid from '../ui/MediaGrid.astro';
import SourceTooltip from '../ui/SourceTooltip.astro';
import { ursachen } from '../../data/content';
---

<Section
  id="ursachen"
  eyebrow="Muster"
  title="Was die Spitzenländer gemeinsam haben"
  intro={ursachen.intro}
>
  <MediaGrid columns={2}>
    {
      ursachen.muster.map((m, i) => (
        <article class="ursachen-info">
          <span class="ursachen-nr" aria-hidden="true">{i + 1}</span>
          <h3 class="ursachen-titel">{m.titel}</h3>
          <p class="ursachen-text">
            {m.text}
            {m.quellen.map((id) => (
              <SourceTooltip id={id} />
            ))}
          </p>
        </article>
      ))
    }
  </MediaGrid>
</Section>

<style>
  .ursachen-info {
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 1rem;
    padding: 1.5rem;
  }
  .ursachen-nr {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--color-ocker);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .ursachen-titel {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
  }
  .ursachen-text {
    margin: 0;
    line-height: 1.65;
    color: var(--color-subtext);
  }
</style>
