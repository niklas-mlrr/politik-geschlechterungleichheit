---
// Hero – visuelles Herzstück des Einstiegs (Sketch S.0).
// Sonder-Sektion: nutzt bewusst NICHT das Section-Primitive, sondern ein eigenes
// <section id="hero">, ist aber für die Anker-Navigation korrekt ausgezeichnet.
import { hero } from '../../data/placeholder';
---

<section id="hero" class="hero" aria-labelledby="hero-h1">
  <div class="hero-inner">
    <p class="hero-kopfzeile">{hero.kopfzeile}</p>

    {/* Semantischer Seitentitel: die Kernaussage trägt das einzige h1. */}
    <h1 id="hero-h1" class="sr-only">
      {hero.claim}: {hero.kernzahl} {hero.kernzahlEinheit} {hero.kernzahlUnterzeile}
    </h1>

    <p class="hero-kernzahl" aria-hidden="true">
      <span class="hero-zahl">{hero.kernzahl}</span>
      <span class="hero-einheit">{hero.kernzahlEinheit}</span>
    </p>

    <p class="hero-unterzeile" aria-hidden="true">{hero.kernzahlUnterzeile}</p>

    <p class="hero-einstieg">{hero.einstieg}</p>
  </div>

  <a class="hero-scroll" href="#definition">
    <span class="hero-scroll-text">{hero.scrollHinweis}</span>
    <span class="hero-scroll-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
        stroke="currentColor" stroke-width="2" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M12 5v14M19 12l-7 7-7-7" />
      </svg>
    </span>
  </a>
</section>

<style>
  .hero {
    min-height: 90svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 6rem 1.25rem 4rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 52rem;
    margin: 0 auto;
  }

  .hero-kopfzeile {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-clay);
    margin: 0 0 1.5rem;
  }

  .hero-kernzahl {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.4em;
    margin: 0;
    line-height: 0.9;
  }
  .hero-zahl {
    font-family: var(--font-display);
    font-weight: 900;
    color: var(--color-clay);
    font-size: clamp(7rem, 26vw, 18rem);
    letter-spacing: -0.02em;
  }
  .hero-einheit {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    font-size: clamp(1.8rem, 6vw, 3.4rem);
  }

  .hero-unterzeile {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    font-size: clamp(1.6rem, 5vw, 3rem);
    line-height: 1.15;
    margin: 0.6rem 0 0;
    text-wrap: balance;
  }

  .hero-einstieg {
    max-width: 40rem;
    margin: 2rem auto 0;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-subtext);
    text-wrap: pretty;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-subtext);
  }
  .hero-scroll-text {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .hero-scroll-arrow {
    display: inline-flex;
    color: var(--color-clay);
    animation: hero-bob 1.8s ease-in-out infinite;
  }
  .hero-scroll:hover .hero-scroll-text {
    color: var(--color-ink);
  }

  @keyframes hero-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(0.35rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-arrow {
      animation: none;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
