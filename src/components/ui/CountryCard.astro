---
// CountryCard – Länder-Ranking-Karte (vgl. Design-Mockup "Island 92,6 % · Platz 1").
// Zeigt Land, Platzierung, Anteil geschlossener Gender Gap als Balken (Choropleth-Farbe).
import { gapColor } from '../../data/tokens';

interface Props {
  land: string;
  platz: number;
  closed: number; // 0..1
  kurz?: string;
}
const { land, platz, closed, kurz } = Astro.props;
const prozent = (closed * 100).toFixed(1).replace('.', ',');
const barColor = gapColor(closed);
---

<article class="cc">
  <header class="cc-head">
    <h3 class="cc-land">{land}</h3>
    <span class="cc-prozent">{prozent}&thinsp;%</span>
  </header>
  <p class="cc-platz">Platz {platz} · Gender Gap geschlossen</p>
  <div
    class="cc-bar"
    role="meter"
    aria-valuenow={Math.round(closed * 100)}
    aria-valuemin="0"
    aria-valuemax="100"
    aria-label={`${land}: ${prozent} Prozent geschlossen`}
  >
    <span class="cc-bar-fill" style={`width:${(closed * 100).toFixed(1)}%; background:${barColor};`}
    ></span>
  </div>
  {kurz && <p class="cc-kurz">{kurz}</p>}
</article>

<style>
  .cc {
    background: var(--color-card);
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 1rem;
    padding: 1.25rem;
  }
  .cc-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .cc-land {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0;
  }
  .cc-prozent {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--color-clay);
  }
  .cc-platz {
    margin: 0.25rem 0 0.9rem;
    font-size: 0.85rem;
    color: var(--color-subtext);
  }
  .cc-bar {
    height: 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-ink) 8%, var(--color-sand));
    overflow: hidden;
  }
  .cc-bar-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
  }
  .cc-kurz {
    margin: 0.9rem 0 0;
    font-size: 0.95rem;
    color: var(--color-ink);
  }
</style>
